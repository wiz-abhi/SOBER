# --- LLM (Gemini) ---
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.5-flash
LLM_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Free-tier protection: throttle cognee's LLM calls so 429s never kill a pipeline run
LLM_RATE_LIMIT_ENABLED=true
LLM_RATE_LIMIT_REQUESTS=8
LLM_RATE_LIMIT_INTERVAL=60

# --- Embeddings: local, no API key, no rate limits ---
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Storage: zero-config local defaults (embedded graph DB + LanceDB + SQLite) ---

# --- Cognee Cloud (Day 2/3 — canary deploys) ---
# COGNEE_SERVICE_URL=
# COGNEE_API_KEY=
